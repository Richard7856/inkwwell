# Inkwell AR — Variables de entorno
# Copiar a .env y rellenar con tus credenciales reales
# NUNCA commitear .env — está en .gitignore

# === SUPABASE ===
# Obtener en: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-key>

# === WORKER DE COMPILACIÓN .mind ===
# Para desarrollo local con ngrok:
#   1. cd worker && npm install && node index.js
#   2. En otra terminal: ngrok http 3001
#   3. Pegar la URL HTTPS de ngrok aquí (sin slash final)
# Para producción (Railway):
#   Pegar la URL del servicio Railway
VITE_COMPILER_URL=https://<tu-id>.ngrok-free.app
